# =============================================================================
# Paper2Code-Enhanced — LLM Provider Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The openai Python client is used for all providers (OpenAI-compatible API).

# -----------------------------------------------------------------------------
# Active provider: MiniMax (via MiniMax API — OpenAI-compatible)
# -----------------------------------------------------------------------------
LLM_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimax.io/anthropic
LLM_MODEL=MiniMax-M2.7

# -----------------------------------------------------------------------------
# Optional inference settings
# -----------------------------------------------------------------------------
# Temperature for generation (default: 0.5). Ignored if LLM_REASONING_EFFORT is set.
LLM_TEMPERATURE=0.5

# Reasoning effort — only set this for models that support it (e.g. OpenAI o3-mini, o4-mini).
# Leave blank/unset for MiniMax, Ollama, OpenRouter models.
# LLM_REASONING_EFFORT=medium

# =============================================================================
# Other provider examples — uncomment one block at a time
# =============================================================================

# --- OpenRouter (access MiniMax, DeepSeek, Llama, etc.) ---------------------
# LLM_API_KEY=your_openrouter_api_key_here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=minimax/minimax-m1-40k

# --- Ollama (local) ----------------------------------------------------------
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# --- OpenAI (original) -------------------------------------------------------
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=
# LLM_MODEL=gpt-4.1
# LLM_REASONING_EFFORT=medium   # only for o-series models
